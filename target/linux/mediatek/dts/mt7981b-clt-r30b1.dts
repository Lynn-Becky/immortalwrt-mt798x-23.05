/dts-v1/;
#include "mt7981b-clt-r30b1.dtsi"

/ {
	model = "CLT R30B1";
	compatible = "clt,r30b1", "mediatek,mt7981";
};

&partitions {
	partition@580000 {
		label = "ubi";
		reg = <0x580000 0x4000000>;
	};

	partition@4580000 {
		label = "data";
		reg = <0x4580000 0x2000000>;
	};
};
